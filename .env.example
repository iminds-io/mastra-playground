NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hono_workspace
WORKSPACE_ROOT=/absolute/path/to/hono-workspace/var/workspaces
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_TOKEN=your-firebase-web-api-key
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# --- Testing infrastructure ---
# Neon REST API — used by integration and E2E tests to create/delete branches
# Get an API key at https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=
NEON_PROJECT_ID=

# Firebase Admin SDK — absolute path to the service account JSON (kept outside the repo)
# Used by E2E and smoke tests to mint test users and their ID tokens
GOOGLE_APPLICATION_CREDENTIALS=

# Smoke tests — deployed worker URL (when empty, smoke tests skip)
SMOKE_BASE_URL=

# Opt into smoke tests that write to the production DB. Set to true only after
# platform + Mastra schema has been migrated to the deployed worker's DB.
SMOKE_REQUIRES_MIGRATED_DB=

# Comma-separated list of Firebase email addresses allowed to mutate Mastra
# editor endpoints (/api/mastra/stored/*). Reads stay open to all authenticated
# callers; write methods (POST/PATCH/PUT/DELETE) are rejected unless the
# verified caller email matches one of these entries (case-insensitive).
ADMIN_EMAILS=
