{
  "name": "mastra-mindspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @mastra-mindspace/app dev",
    "dev:full": "concurrently -k -n backend,frontend -c blue,green \"pnpm dev\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @mastra-mindspace/web dev",
    "dev:db": "docker-compose up -d postgres",
    "dev:db:down": "docker-compose down",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "pnpm --filter @mastra-mindspace/worker run test:e2e",
    "test:smoke": "pnpm --filter @mastra-mindspace/worker run test:smoke",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "concurrently": "9.2.1",
    "jose": "6.2.2",
    "tsx": "4.20.6",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
